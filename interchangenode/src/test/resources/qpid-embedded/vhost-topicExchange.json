{
  "type": "Memory",
  "name": "localhost",
  "modelVersion": "7.0",
  "exchanges": [
    {
      "name": "headerEx",
      "type": "headers",
      "durable": true,
      "durableBindings": [
        {
          "arguments": {
            "x-filter-jms-selector": "how = 'fisk' and what = 'torsk'"
          },
          "bindingKey": "headerFiskTorsk",
          "destination": "qFiskTorsk"
        }
      ]
    },
    {
      "name": "topicEx",
      "type": "topic",
      "durable": true,
      "durableBindings": [
        {
          "bindingKey": "fisk.torsk",
          "destination": "qFiskTorsk"
        }
      ],
      "alternateBinding" : {
        "destination" : "headerEx"
      }
    }
  ],
  "queues": [
    {
      "name": "qFiskTorsk",
      "type": "standard",
      "durable": true,
      "holdOnPublishEnabled": false
    }
  ]
}